  "keyFeatures": [
    "End-to-end TypeScript type safety from server to client",
    "First-class OpenAPI spec generation",
    "Contract-first API development with @orpc/contract",
    "Middleware and plugin system",
    "Multi-runtime support: Node.js, Bun, Deno, Cloudflare Workers",
    "Framework integrations: TanStack Query, SWR, Pinia Colada",
    "Server Actions support for Next.js and TanStack Start",
    "Streaming and SSE with full type safety",
    "Standard Schema support: Zod, Valibot, ArkType",
    "OpenTelemetry integration for observability",
    "Lazy router for improved cold start performance",
    "WebSocket support via crossws, ws, and Bun WebSocket"
  ],
  "publicApiSurface": [
    "os (Builder) - @orpc/server",
    "oc (ContractBuilder) - @orpc/contract",
    "RPCHandler - @orpc/server/node, /fetch, /fastify, /aws-lambda",
    "createORPCClient - @orpc/client",
    "RPCLink - @orpc/client/fetch",
    "OpenAPIGenerator - @orpc/openapi",
    "OpenAPIHandler - @orpc/openapi",
    "ORPCError - @orpc/client",
    "RouterClient<T> - @orpc/server",
    "useQuery / useMutation (orpc utils) - @orpc/tanstack-query",
    "CORSPlugin - @orpc/server/plugins",
    "BatchPlugin - @orpc/server/plugins",
    "ORPCInstrumentation - @orpc/otel",
    "implement() - @orpc/nest",
    "orpcAction / experimental_orpcAction - @orpc/react",
    "ZodToJsonSchemaConverter - @orpc/zod",
    "eventIterator - @orpc/contract"
  ]
}
